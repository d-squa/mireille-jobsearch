# Non-secret pipeline configuration.
# Edit this file directly (on GitHub or locally) to change search
# behavior, scoring, or logging - no YAML, no workflow file, no
# secrets involved. The GitHub Actions workflows load this file
# automatically and layer real secrets (API keys) on top of it.

# Comma-separated search terms sent to Jooble/Reed/Adzuna.
SEARCH_TERMS=Remote,Food Scientist, Junior Food Scientist, Graduate Food Scientist, Food Technologist, Junior Food Technologist, Graduate Food Technologist, QA Technician, Quality Assurance Technician, QA Assistant, Quality Assurance Assistant, QC Technician, Quality Control Technician, Quality Control Assistant, Food Safety Technician, Food Safety Assistant, Food Safety Coordinator, HACCP Assistant, Compliance Assistant, Regulatory Affairs Assistant, Label Compliance Assistant, Documentation Specialist, Laboratory Technician, Food Laboratory Technician, Microbiology Technician, Microbiology Lab Technician, Chemistry Lab Technician, Analytical Technician, R&D Assistant, Research Assistant (Food), Product Development Assistant, Test Kitchen Assistant, Sensory Technician, Consumer Testing Assistant, Product Evaluation Assistant, Production Technician, Process Technician, Manufacturing Associate, Production Planner Assistant, Production Supervisor Trainee, Packaging Technician, Packaging Technologist Assistant, Packaging Development Technician, Ingredient Sourcing Assistant, Procurement Coordinator, Raw Materials Coordinator, Technical Sales Representative (Food), Application Specialist (Food), Customer Technical Support (Food), Food Inspector Trainee, Agricultural Inspector, Public Health Laboratory Assistant,Remote

# Optional. Comma-separated terms - any job whose title contains one
# (case-insensitive) is dropped before matching/scoring, regardless of
# what it would otherwise match. Simple substring matching, not fuzzy -
# e.g. "Intern" also excludes "Marketing Internship". Leave blank to
# disable (no jobs excluded).
EXCLUDE_TERMS=

# ISO country codes to search, comma-separated. Reed ignores this
# (UK-only). Adzuna only supports ~20 countries (not Gulf/MENA) - sa,
# kw, and lb are not in Adzuna's supported list and will be skipped
# automatically for that source (not an error) - Jooble still searches
# them normally.
SEARCH_COUNTRIES=gb,us,de,fr,nl,pt,es,ie,ch

TITLE_SCORES_FILE=./config/title_scores.json
FUZZY_MATCH_THRESHOLD=82
ATS_WATCHLIST_FILE=./config/ats_watchlist.json
MIN_SCORE=50

DATABASE_PATH=./data/lead_discovery.db
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service_account.json

LOG_LEVEL=INFO
LOG_FILE=./logs/lead_discovery.log
